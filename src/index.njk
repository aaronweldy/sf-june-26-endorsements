<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <title>{{ site.title }}</title>
        <link rel="stylesheet" href="index.css" />
    </head>
    <body>
        <header>
            <h1>{{ site.page_title }}</h1>
            <div class="sub">{{ site.org_count }} organizations · regenerated {{ site.regenerated }}</div>
        </header>
        <nav class="toc">
            <strong style="margin-right: 8px">Jump to:</strong>
            <a href="#federal">Federal</a>
            <a href="#statewide">Statewide</a>
            <a href="#legislature">Legislature</a>
            <a href="#judicial">Judicial</a>
            <a href="#supes">Supervisors</a>
            <a href="#boe">School Board</a>
            <a href="#measures">Props A–D</a>
        </nav>
        <main>
            <section>
                <div class="legend">
                    Each candidate has a distinct color within a race — scan a
                    column for consensus vs. splits. Color key sits above each
                    table. Org names link to that org's June 2026 endorsement
                    page. &nbsp;<span
                        class="swatch"
                        style="background: var(--yes-bg); color: var(--yes-fg)"
                        >YES</span
                    >
                    <span
                        class="swatch"
                        style="background: var(--no-bg); color: var(--no-fg)"
                        >NO</span
                    >
                    <span
                        class="swatch"
                        style="
                            background: var(--none-bg);
                            color: var(--none-fg);
                        "
                        >X</span
                    >=no endorsement located/not in retrievable snapshot
                    <span
                        class="swatch"
                        style="
                            background: var(--noend-bg);
                            color: var(--noend-fg);
                            font-style: italic;
                        "
                        >No Endorse¹</span
                    >=formal no-rec · <code>¹</code> formal no-rec &nbsp;<code
                        >²</code
                    >
                    dual/ranked &nbsp;<code>³</code> early/preliminary
                    &nbsp;<code>⁴</code> possibly stale
                </div>
            </section>
            {%- for sg in races %}
            <section id="{{ sg.section }}">
                <h2>{{ sg.label }}</h2>
                {%- if sg.section == "measures" %}
                {%- set race = sg.races[0] %}
                {%- include "measures.njk" %}
                {%- else %}
                {%- for race in sg.races %}
                {%- include "race.njk" %}
                {%- endfor %}
                {%- endif %}
            </section>
            {%- endfor %}
            <section>
                <div class="meta">
                    <strong>Sources &amp; methodology.</strong> Endorsements
                    assembled from direct fetches of each organization's
                    published June 2, 2026 endorsement page, supplemented by
                    Peter Xu's
                    <a
                        href="https://sfendorsements.com/"
                        target="_blank"
                        rel="noopener"
                        >SF Endorsements aggregator</a
                    >
                    (34 orgs as of May 16, 2026), the
                    <a
                        href="https://en.wikipedia.org/wiki/2026_California_gubernatorial_election"
                        target="_blank"
                        rel="noopener"
                        >Wikipedia 2026 CA gubernatorial endorsements list</a
                    >, and
                    <a
                        href="https://fullertonobserver.com/2026/05/11/ca-2026-primary-ballot-endorsements-resource-info/"
                        target="_blank"
                        rel="noopener"
                        >Fullerton Observer's statewide group compilation</a
                    >. <br />
                    A blank cell ("X") means the org has not publicly endorsed
                    in that race (or the endorsement was not in the retrievable
                    snapshot). "No endorsement¹" = formal vote of no
                    recommendation. Mission Local and SF Standard are reporting
                    outlets that don't endorse. Notable not-yet-published /
                    not-retrievable slates: SF Chronicle (governor and AG
                    missing from aggregator), UESF (only Chan + Cheung
                    confirmed). DSA SF doesn't appear to have published a
                    SF-specific June 2026 slate.
                </div>
            </section>
        </main>
        <script>
            (function () {
                // Initialize data-candidate on swatches and rows, scoped per race
                document.querySelectorAll(".race-cands").forEach(function (cands) {
                    // Find the associated table (next .scroll sibling)
                    var scroll = cands.nextElementSibling;
                    if (!scroll || !scroll.classList.contains("scroll")) return;

                    // Find candidate class on each swatch
                    cands.querySelectorAll(".swatch").forEach(function (swatch) {
                        var candClass = Array.from(swatch.classList).find(function (c) {
                            return /^c\d+$/.test(c);
                        });
                        if (candClass) {
                            swatch.dataset.candidate = candClass;
                        }
                    });

                    // Find candidate class on each row in this race's table only
                    scroll.querySelectorAll("tbody tr").forEach(function (row) {
                        var td = row.querySelector("td.cand");
                        if (!td) return;
                        var candClass = Array.from(td.classList).find(function (c) {
                            return /^c\d+$/.test(c);
                        });
                        if (candClass) {
                            row.dataset.candidate = candClass;
                        }
                    });
                });

                function getRace(swatch) {
                    return swatch.closest(".race-cands");
                }

                function getRaceRows(race) {
                    var scroll = race.nextElementSibling;
                    if (scroll && scroll.classList.contains("scroll")) {
                        return scroll.querySelectorAll("tbody tr");
                    }
                    return [];
                }

                function getLockedSwatch(race) {
                    return race.querySelector(".swatch.locked");
                }

                function clearLocks(race) {
                    var locked = race.querySelector(".swatch.locked");
                    if (locked) locked.classList.remove("locked");
                }

                function highlight(race, candClass) {
                    getRaceRows(race).forEach(function (row) {
                        if (row.dataset.candidate === candClass) {
                            row.classList.remove("row-dim");
                        } else {
                            row.classList.add("row-dim");
                        }
                    });
                }

                function clearHighlight(race) {
                    getRaceRows(race).forEach(function (row) {
                        row.classList.remove("row-dim");
                    });
                }

                // Attach handlers to each swatch
                document.querySelectorAll(".race-cands .swatch").forEach(function (swatch) {
                    var candClass = swatch.dataset.candidate;
                    if (!candClass) return;

                    swatch.addEventListener("mouseenter", function () {
                        var race = getRace(swatch);
                        highlight(race, candClass);
                    });

                    swatch.addEventListener("mouseleave", function () {
                        var race = getRace(swatch);
                        var lockedSwatch = getLockedSwatch(race);
                        if (!lockedSwatch) {
                            clearHighlight(race);
                        } else if (lockedSwatch !== swatch) {
                            highlight(race, lockedSwatch.dataset.candidate);
                        }
                    });

                    swatch.addEventListener("click", function () {
                        var race = getRace(swatch);
                        if (swatch.classList.contains("locked")) {
                            swatch.classList.remove("locked");
                            clearHighlight(race);
                        } else {
                            clearLocks(race);
                            swatch.classList.add("locked");
                            highlight(race, candClass);
                        }
                    });
                });
            })();
        </script>
    </body>
</html>
