<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <title>{{ site.title }}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
        <link rel="stylesheet" href="index.css" />
    </head>
    <body>
        <header>
            <h1>{{ site.page_title }}</h1>
        </header>
        <nav class="toc">
            <strong style="margin-right: 8px">Jump to:</strong>
            <a href="#federal">Federal</a>
            <a href="#statewide">Statewide</a>
            <a href="#legislature">Legislature</a>
            <a href="#judicial">Judicial</a>
            <a href="#supes">Supervisors</a>
            <a href="#boe">School Board</a>
            <a href="#measures">Props A–D</a>
        </nav>
        <main>
            {%- for sg in races %}
            <section id="{{ sg.section }}">
                <h2>{{ sg.label }}</h2>
                {%- if sg.section == "measures" %}
                {%- set race = sg.races[0] %}
                {%- include "measures.njk" %}
                {%- else %}
                {%- for race in sg.races %}
                {%- include "race.njk" %}
                {%- endfor %}
                {%- endif %}
            </section>
            {%- endfor %}
        </main>
        <script>
            (function () {
                // Initialize data-candidate on swatches and rows, scoped per race
                document.querySelectorAll(".race-cands").forEach(function (cands) {
                    // Find the associated table (next .scroll sibling)
                    var scroll = cands.nextElementSibling;
                    if (!scroll || !scroll.classList.contains("scroll")) return;

                    // Find candidate class on each swatch
                    cands.querySelectorAll(".swatch").forEach(function (swatch) {
                        var candClass = Array.from(swatch.classList).find(function (c) {
                            return /^c\d+$/.test(c);
                        });
                        if (candClass) {
                            swatch.dataset.candidate = candClass;
                        }
                    });

                    // Find candidate class on each row in this race's table only
                    scroll.querySelectorAll("tbody tr").forEach(function (row) {
                        var td = row.querySelector("td.cand");
                        if (!td) return;
                        var candClass = Array.from(td.classList).find(function (c) {
                            return /^c\d+$/.test(c);
                        });
                        if (candClass) {
                            row.dataset.candidate = candClass;
                        } else {
                            // multi-endorsement: extract which candidate colors appear in the gradient style
                            var style = td.getAttribute("style") || "";
                            var matches = style.match(/--c(\d+)-bg/g) || [];
                            if (matches.length) {
                                row.dataset.candidates = matches.map(function (m) {
                                    return m.slice(2, -3); // "--c1-bg" -> "c1"
                                }).join(" ");
                            }
                        }
                    });
                });

                function getRace(swatch) {
                    return swatch.closest(".race-cands");
                }

                function getRaceRows(race) {
                    var scroll = race.nextElementSibling;
                    if (scroll && scroll.classList.contains("scroll")) {
                        return scroll.querySelectorAll("tbody tr");
                    }
                    return [];
                }

                function getLockedSwatch(race) {
                    return race.querySelector(".swatch.locked");
                }

                function clearLocks(race) {
                    var locked = race.querySelector(".swatch.locked");
                    if (locked) locked.classList.remove("locked");
                }

                function rowMatchesCand(row, candClass) {
                    if (row.dataset.candidate === candClass) return true;
                    if (row.dataset.candidates) {
                        return row.dataset.candidates.split(" ").indexOf(candClass) !== -1;
                    }
                    return false;
                }

                function highlight(race, candClass) {
                    getRaceRows(race).forEach(function (row) {
                        if (rowMatchesCand(row, candClass)) {
                            row.classList.remove("row-dim");
                        } else {
                            row.classList.add("row-dim");
                        }
                    });
                }

                function clearHighlight(race) {
                    getRaceRows(race).forEach(function (row) {
                        row.classList.remove("row-dim");
                    });
                }

                // Attach handlers to each swatch
                document.querySelectorAll(".race-cands .swatch").forEach(function (swatch) {
                    var candClass = swatch.dataset.candidate;
                    if (!candClass) return;

                    swatch.addEventListener("mouseenter", function () {
                        var race = getRace(swatch);
                        highlight(race, candClass);
                    });

                    swatch.addEventListener("mouseleave", function () {
                        var race = getRace(swatch);
                        var lockedSwatch = getLockedSwatch(race);
                        if (!lockedSwatch) {
                            clearHighlight(race);
                        } else if (lockedSwatch !== swatch) {
                            highlight(race, lockedSwatch.dataset.candidate);
                        }
                    });

                    swatch.addEventListener("click", function () {
                        var race = getRace(swatch);
                        if (swatch.classList.contains("locked")) {
                            swatch.classList.remove("locked");
                            clearHighlight(race);
                        } else {
                            clearLocks(race);
                            swatch.classList.add("locked");
                            highlight(race, candClass);
                        }
                    });
                });
            })();
        </script>
    </body>
</html>
