<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <title>{{ site.title }}</title>
        <meta name="description" content="{{ site.description }}" />
        <meta name="robots" content="index,follow" />
        <link rel="canonical" href="{{ site.url }}/" />

        <link rel="icon" href="favicon.ico" sizes="any" />
        <link rel="icon" type="image/svg+xml" href="favicon.svg" />
        <link rel="icon" type="image/png" sizes="16x16" href="favicon-16x16.png" />
        <link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png" />
        <link rel="icon" type="image/png" sizes="48x48" href="favicon-48x48.png" />
        <link rel="icon" type="image/png" sizes="512x512" href="favicon-512x512.png" />
        <link rel="apple-touch-icon" sizes="180x180" href="favicon-180x180.png" />

        <meta property="og:type" content="website" />
        <meta property="og:url" content="{{ site.url }}/" />
        <meta property="og:title" content="{{ site.page_title }}" />
        <meta property="og:description" content="{{ site.description }}" />
        <meta property="og:site_name" content="{{ site.site_name }}" />
        <meta property="og:locale" content="en_US" />
        <meta property="og:image" content="{{ site.url }}/og.png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content="{{ site.url }}/" />
        <meta name="twitter:title" content="{{ site.page_title }}" />
        <meta name="twitter:description" content="{{ site.description }}" />
        <meta name="twitter:image" content="{{ site.url }}/og.png" />

        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "WebSite",
          "name": "{{ site.site_name }}",
          "url": "{{ site.url }}/",
          "description": "{{ site.description }}",
          "inLanguage": "en-US",
          "about": {
            "@type": "Event",
            "name": "San Francisco June 2, 2026 Primary Election",
            "startDate": "2026-06-02",
            "location": {
              "@type": "Place",
              "name": "San Francisco, California",
              "address": {
                "@type": "PostalAddress",
                "addressLocality": "San Francisco",
                "addressRegion": "CA",
                "addressCountry": "US"
              }
            }
          }
        }
        </script>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
        <link rel="stylesheet" href="index.css" />
    </head>
    <body>
        <header>
            <div class="header-inner">
                <h1>{{ site.page_title }}</h1>
                <div class="header-links">
                    <a href="https://x.com/intent/post?text=San%20Francisco%20June%202%2C%202026%20primary%20endorsement%20grid&url=https%3A%2F%2Fsfvoterguide.com%2F" target="_blank" rel="noopener" aria-label="Share on X">
                        <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                    <a href="https://github.com/aaronweldy/sf-june-26-endorsements" target="_blank" rel="noopener" aria-label="View source on GitHub">
                        <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                    </a>
                </div>
            </div>
        </header>
        <nav class="toc">
            <strong style="margin-right: 8px">Jump to:</strong>
            <a href="#federal">Federal</a>
            <a href="#statewide">Statewide</a>
            <a href="#legislature">Legislature</a>
            <a href="#judicial">Judicial</a>
            <a href="#supes">Supervisors</a>
            <a href="#boe">School Board</a>
            <a href="#measures">Props A–D</a>
        </nav>
        <main>
            {%- for sg in races %}
            <section id="{{ sg.section }}">
                <h2>{{ sg.label }}</h2>
                {%- if sg.section == "measures" %}
                {%- set race = sg.races[0] %}
                {%- include "measures.njk" %}
                {%- else %}
                {%- for race in sg.races %}
                {%- include "race.njk" %}
                {%- endfor %}
                {%- endif %}
            </section>
            {%- endfor %}
        </main>
        <script>
            (function () {
                // Initialize data-candidate on swatches and rows, scoped per race
                document.querySelectorAll(".race-cands").forEach(function (cands) {
                    // Find the associated table (next .scroll sibling)
                    var scroll = cands.nextElementSibling;
                    if (!scroll || !scroll.classList.contains("scroll")) return;

                    // Find candidate class on each swatch
                    cands.querySelectorAll(".swatch").forEach(function (swatch) {
                        var candClass = Array.from(swatch.classList).find(function (c) {
                            return /^c\d+$/.test(c);
                        });
                        if (candClass) {
                            swatch.dataset.candidate = candClass;
                        }
                    });

                    // Find candidate class on each row in this race's table only
                    scroll.querySelectorAll("tbody tr").forEach(function (row) {
                        var td = row.querySelector("td.cand");
                        if (!td) return;
                        var candClass = Array.from(td.classList).find(function (c) {
                            return /^c\d+$/.test(c);
                        });
                        if (candClass) {
                            row.dataset.candidate = candClass;
                        } else {
                            // multi-endorsement: extract which candidate colors appear in the gradient style
                            var style = td.getAttribute("style") || "";
                            var matches = style.match(/--c(\d+)-bg/g) || [];
                            if (matches.length) {
                                row.dataset.candidates = matches.map(function (m) {
                                    return m.slice(2, -3); // "--c1-bg" -> "c1"
                                }).join(" ");
                            }
                        }
                    });
                });

                function getRace(swatch) {
                    return swatch.closest(".race-cands");
                }

                function getRaceRows(race) {
                    var scroll = race.nextElementSibling;
                    if (scroll && scroll.classList.contains("scroll")) {
                        return scroll.querySelectorAll("tbody tr");
                    }
                    return [];
                }

                function getLockedSwatch(race) {
                    return race.querySelector(".swatch.locked");
                }

                function clearLocks(race) {
                    var locked = race.querySelector(".swatch.locked");
                    if (locked) locked.classList.remove("locked");
                }

                function rowMatchesCand(row, candClass) {
                    if (row.dataset.candidate === candClass) return true;
                    if (row.dataset.candidates) {
                        return row.dataset.candidates.split(" ").indexOf(candClass) !== -1;
                    }
                    return false;
                }

                function highlight(race, candClass) {
                    getRaceRows(race).forEach(function (row) {
                        if (rowMatchesCand(row, candClass)) {
                            row.classList.remove("row-dim");
                        } else {
                            row.classList.add("row-dim");
                        }
                    });
                }

                function clearHighlight(race) {
                    getRaceRows(race).forEach(function (row) {
                        row.classList.remove("row-dim");
                    });
                }

                // Attach handlers to each swatch
                document.querySelectorAll(".race-cands .swatch").forEach(function (swatch) {
                    var candClass = swatch.dataset.candidate;
                    if (!candClass) return;

                    swatch.addEventListener("mouseenter", function () {
                        var race = getRace(swatch);
                        highlight(race, candClass);
                    });

                    swatch.addEventListener("mouseleave", function () {
                        var race = getRace(swatch);
                        var lockedSwatch = getLockedSwatch(race);
                        if (!lockedSwatch) {
                            clearHighlight(race);
                        } else if (lockedSwatch !== swatch) {
                            highlight(race, lockedSwatch.dataset.candidate);
                        }
                    });

                    swatch.addEventListener("click", function () {
                        var race = getRace(swatch);
                        if (swatch.classList.contains("locked")) {
                            swatch.classList.remove("locked");
                            clearHighlight(race);
                        } else {
                            clearLocks(race);
                            swatch.classList.add("locked");
                            highlight(race, candClass);
                        }
                    });
                });
            })();
        </script>
    </body>
</html>
